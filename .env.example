# ─────────────────────────────────────────────────────────────
# ScholarForge_AI — Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# All settings have sensible defaults in src/core/config.py.

# --- API Keys (at least one LLM key is required) ---
# OpenAI Configuration (Optional — leave blank if using Hugging Face)
OPENAI_API_KEY=

# Hugging Face Configuration (Free open source alternative)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# --- Infrastructure ---
PROJECT_NAME="ScholarForge_AI"
DATABASE_URL="postgresql://scholarforge:scholarforge@localhost:15432/scholarforge"
REDIS_URL="redis://localhost:16379/0"
CHROMA_DB_DIR="./chroma_data"

# --- Model Configuration ---
LLM_MODEL_NAME="meta-llama/Meta-Llama-3-8B-Instruct"
EMBEDDING_MODEL_NAME="sentence-transformers/all-MiniLM-L6-v2"
RERANKER_MODEL_NAME="cross-encoder/ms-marco-MiniLM-L-6-v2"

# --- Chunking ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- Retrieval ---
SEMANTIC_CACHE_THRESHOLD=0.10
RERANKER_TOP_K=5
HYBRID_SEARCH_K=20
BM25_TTL_SECONDS=300

# --- Security ---
SCHOLARFORGE_API_KEY=your_scholarforge_api_key_here
CORS_ORIGINS="*"
MAX_UPLOAD_SIZE_MB=50
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# --- LLM Parameters ---
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3
HYDE_MAX_TOKENS=150
MEMORY_MAX_TOKENS=3000

# --- Frontend ---
API_BASE_URL="http://127.0.0.1:8000/api/v1"

# --- Logging ---
LOG_LEVEL=INFO
